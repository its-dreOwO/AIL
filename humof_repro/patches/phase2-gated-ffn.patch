+class SwiGLUFeedForward(nn.Module):
+    """Param-matched SwiGLU replacement for the plain ReLU FFN.
+
+    The baseline FFN is Linear(d->ff) -> ReLU -> Dropout -> Linear(ff->d), i.e.
+    2*d*ff + ff + d params. SwiGLU needs three projections instead of two, so we
+    scale the hidden width by 2/3 to hold the parameter count fixed:
+    3*d*h + 2h + d with h = round(2*ff/3). Without that, a win would confound
+    gating with ~50% extra FFN capacity.
+
+    Output stays dim_q, so the caller's dct_scale_4_dim2 multiply and the
+    se_ffn DCTRescalingLayer are unaffected.
+
+    Note this bundles two changes vs. the baseline: the gate, and ReLU -> SiLU.
+    A delta cannot be split between them (ReGLU would isolate the gate alone).
+    """
+
+    def __init__(self, dim, ff_dim, dropout):
+        super().__init__()
+        hidden = round(2 * ff_dim / 3)
+        self.hidden = hidden
+        self.w_gate = nn.Linear(dim, hidden)
+        self.w_up = nn.Linear(dim, hidden)
+        self.w_down = nn.Linear(hidden, dim)
+        self.dropout = nn.Dropout(dropout)
+
+    def forward(self, x):
+        return self.w_down(self.dropout(F.silu(self.w_gate(x)) * self.w_up(x)))
+
+
 class TransformerLayer(nn.Module):
